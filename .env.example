# Spotify Configuration (Premium account required)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# YouTube Configuration (optional, falls back to search if not set)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Weather API Key
WEATHERAPI_KEY=your_weatherapi_key_here

# Minecraft executable path (optional)
# Windows example: C:\Program Files\Minecraft Launcher\MinecraftLauncher.exe
# Mac example: /Applications/Minecraft.app/Contents/MacOS/Minecraft
# Linux example: /usr/bin/minecraft-launcher
MINECRAFT_PATH=
